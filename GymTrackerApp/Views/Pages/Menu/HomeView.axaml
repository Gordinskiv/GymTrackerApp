<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PracticaGymTracker.ViewModels"
             x:DataType="vm:HomeViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PracticaGymTracker.Views.Pages.HomeView">

    <ScrollViewer Padding="30">
        <StackPanel Spacing="25">
            
            <TextBlock Text="{Binding WelcomeMessage}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource AccentMain}"/>
            <TextBlock Text="{DynamicResource DashboardReady}" FontSize="18" Foreground="{DynamicResource TextMuted}" Margin="0,-15,0,10"/>
            
            <Border Background="{DynamicResource BgCard}" CornerRadius="16" Padding="25" BoxShadow="0 4 15 0 #22000000">
                <StackPanel Spacing="15">
                    <TextBlock Text="{DynamicResource LastActivity}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextWhite}"/>
                    <Border Background="{DynamicResource BgDark}" CornerRadius="8" Padding="20">
                        <TextBlock Text="{Binding LastWorkoutText}" FontSize="18" Foreground="{DynamicResource AccentMain}" FontWeight="Bold" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
            
            <UniformGrid Columns="2" Margin="0,5,0,0">
                 <Border Background="{DynamicResource BgCard}" CornerRadius="12" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalWorkouts}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource TextWhite}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TotalTraining}" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource BgCard}" CornerRadius="12" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Activity}" FontSize="36" FontWeight="Black" Foreground="#00FF00" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource StatusProfile}" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
            
            <Border Background="{DynamicResource AccentMain}" CornerRadius="16" Padding="25" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Quote}" FontSize="14" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,0,10" Opacity="0.8"/>
                    <TextBlock Text="{DynamicResource QuoteDiscipline}" 
                               FontSize="20" FontStyle="Italic" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>