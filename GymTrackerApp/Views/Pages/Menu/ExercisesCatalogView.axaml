<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mod="using:PracticaGymTracker.Models"
             xmlns:vm="using:PracticaGymTracker.ViewModels"
             x:DataType="vm:ExercisesCatalogViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PracticaGymTracker.Views.Pages.ExercisesCatalogView">
    <Grid ColumnDefinitions="*, 1.2*" Margin="20">
        
        <ScrollViewer Grid.Column="0" Margin="0,0,20,0">
            <ItemsControl ItemsSource="{Binding Catalog}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="{Binding GroupName}" 
                                       Foreground="{DynamicResource AccentMain}" 
                                       FontWeight="Black" FontSize="16" Margin="0,0,0,10"/>
                            <ListBox ItemsSource="{Binding Exercises}" 
                                     SelectedItem="{Binding $parent[UserControl].((vm:ExercisesCatalogViewModel)DataContext).SelectedExercise}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BgCard}" CornerRadius="8" Padding="15,10" Margin="0,2">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextWhite}" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <Border Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="16" Padding="25">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsVisible="{Binding SelectedExercise, Converter={x:Static ObjectConverters.IsNull}}">
                    <TextBlock Text="Виберіть вправу зі списку" 
                               Foreground="{DynamicResource TextMuted}" 
                               FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                <ScrollViewer IsVisible="{Binding SelectedExercise, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{Binding SelectedExercise.Name}" 
                                   FontSize="26" FontWeight="Black" Foreground="{DynamicResource TextWhite}"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="{DynamicResource AccentMain}" CornerRadius="6" Padding="12,6">
                                <TextBlock Text="{Binding SelectedExercise.TargetMuscle}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <Border BorderBrush="{DynamicResource AccentMain}" BorderThickness="1.5" CornerRadius="6" Padding="12,6"
                                    IsVisible="{Binding SelectedExercise.SecondaryTargetMuscle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding SelectedExercise.SecondaryTargetMuscle}" Foreground="{DynamicResource AccentMain}" FontWeight="Bold" FontSize="12"/>
                            </Border>
                        </StackPanel>
                        
                        <Border Background="{DynamicResource BgDark}" ClipToBounds="True" CornerRadius="12" Margin="0,10" MinHeight="250"
                                IsVisible="{Binding SelectedExercise.ImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
    
                            <Image Source="{Binding SelectedExercise.ImageBitmap}" 
                                   Stretch="Uniform" 
                                   MaxHeight="350"/>
                        </Border>
                        
                        <TextBlock Text="{DynamicResource PerformanceTechnique}" FontWeight="Black" Foreground="{DynamicResource TextMuted}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding SelectedExercise.Description}" 
                                   Foreground="{DynamicResource TextWhite}" 
                                   TextWrapping="Wrap" 
                                   FontSize="15"
                                   LineHeight="24"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>